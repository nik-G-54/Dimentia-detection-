# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cogniscreen

# Server
PORT=5000

# Frontend URL (for CORS) - Add your deployed frontend URL here
FRONTEND_URL=http://localhost:3000

# Additional Origins (optional) - comma separated list
# ADDITIONAL_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# JWT Secret
JWT_SECRET=your-secret-key-here

# Email Service (if using)
RESEND_API_KEY=your-resend-api-key

# Google Generative AI
GOOGLE_API_KEY=your-google-api-key

# Redis (for Bull queue)
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
